  "gene_population_patterns": [
    {
      "variant": "rs12913832 / rs1129038 pigmentation haplotype",
      "location_group": "Pigmentation cohorts",
      "summary": "Across global datasets, the light-eye-associated rs12913832-rs1129038 background is strongly enriched in Europe and uncommon in Africa and East Asia, which is consistent with selection and historical structure at the HERC2/OCA2 pigmentation locus.",
      "evidence": [
        {
          "label": "PubMed 22065085 / PMCID PMC3325407",
          "url": "https://pubmed.ncbi.nlm.nih.gov/22065085/"
        }
      ]
    },
    {
      "variant": "HERC2 eye-colour prediction exceptions",
      "location_group": "Forensic cohorts",
      "summary": "Recent sequencing studies show that rs12913832 alone does not explain every observed eye-colour outcome, and additional OCA2-HERC2 or pigmentation-locus variants can account for many blue-eyed AA or AG individuals and many brown-eyed GG individuals.",
      "evidence": [
        {
          "label": "PubMed 36980970 / PMCID PMC10048254",
          "url": "https://pubmed.ncbi.nlm.nih.gov/36980970/"
        },
        {
          "label": "PubMed 32915910 / PMCID PMC7485777",
          "url": "https://pubmed.ncbi.nlm.nih.gov/32915910/"
        }
      ]
    },
    {
      "variant": "Pigmentation-linked cancer background",
      "location_group": "Cancer cohorts",
      "summary": "Common HERC2/OCA2 pigmentation markers, including rs12913832 and rs916977, have been associated with uveal melanoma or cutaneous squamous-cell carcinoma risk through pigmentation background rather than a direct cancer-driver mechanism.",
      "evidence": [
        {
          "label": "PubMed 27499155 / PMCID PMC4976361",
          "url": "https://pubmed.ncbi.nlm.nih.gov/27499155/"
        },
        {
          "label": "PubMed 28456133",
          "url": "https://pubmed.ncbi.nlm.nih.gov/28456133/"
        }
