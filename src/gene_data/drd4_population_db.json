    {
      "variant": "Exon III 48-bp VNTR",
      "location_group": "Europe and the Americas",
      "summary": "The 7-repeat allele is comparatively more common in many European-ancestry and admixed American cohorts than in East Asian cohorts, which is why many ADHD and novelty-seeking studies in these groups focus on 7R carriage.",
      "evidence": [
        {
          "label": "PMC3653059",
          "url": "https://pmc.ncbi.nlm.nih.gov/articles/PMC3653059/"
